# Optional. If empty, the app picks a dev default (localhost on web/iOS sim, 10.0.2.2 on Android emulator).
# On a physical device, set this to the PC that runs `npm run api` (ipconfig IPv4) — not server/.env DB_SERVER.
# Vercel (web): set the same vars in the project’s Environment Variables (HTTPS URL of your hosted API).

EXPO_PUBLIC_API_URL=
EXPO_PUBLIC_SOCKET_URL=

# Examples:
# EXPO_PUBLIC_API_URL=http://localhost:4000
# EXPO_PUBLIC_API_URL=http://10.0.2.2:4000
# EXPO_PUBLIC_API_URL=http://192.168.1.100:4000
